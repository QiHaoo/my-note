---
import { getTopics, getSiteConfig } from '../lib/content';

const topics = getTopics();
const currentTopic = Astro.params.topic as string | undefined;
const currentChapter = Astro.params.chapter as string | undefined;
const config = getSiteConfig();
const base = import.meta.env.BASE_URL || '';
---

<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 w-72 -translate-x-full transform border-r border-[var(--border)] bg-[var(--surface)] transition-transform duration-200 md:static md:translate-x-0"
>
  <div class="flex h-full flex-col p-4">
    <a href={`${base}/`} class="mb-6 text-lg font-semibold text-[var(--heading)]">
      {config.title}
    </a>

    <nav class="flex-1 space-y-2 overflow-y-auto" id="topic-accordion">
      {topics.map((topic) => {
        const isActive = currentTopic === topic.slug;
        const chapterCount = topic.chapters.length;
        return (
          <div class="topic-group rounded-lg" data-topic={topic.slug} data-active={isActive}>
            <button
              type="button"
              class="topic-header flex w-full items-center justify-between rounded-lg px-3 py-2.5 text-left transition-colors hover:bg-[var(--bg)]"
              aria-expanded={isActive}
            >
              <span class={`text-sm font-medium ${isActive ? 'text-[var(--accent)]' : 'text-[var(--heading)]'}`}>
                {topic.meta.icon && <span class="mr-2">{topic.meta.icon}</span>}
                {topic.meta.title}
                <span class="ml-1 text-xs text-[var(--text)] opacity-70">（{chapterCount}讲）</span>
              </span>
              <svg
                class={`topic-chevron h-4 w-4 text-[var(--text)] transition-transform duration-200 ${isActive ? 'rotate-180' : ''}`}
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <ul class={`topic-chapters mt-1 space-y-0.5 overflow-hidden transition-all duration-200 ${isActive ? 'max-h-[1000px] opacity-100' : 'max-h-0 opacity-0'}`}>
              {topic.chapters.map((chapter) => {
                const isCurrentChapter = isActive && currentChapter === chapter.slug;
                const order = String(chapter.order).padStart(2, '0');
                return (
                  <li>
                    <a
                      href={`${base}/${topic.slug}/${chapter.slug}/`}
                      class={`block rounded-md px-3 py-2 text-sm transition-colors ${isCurrentChapter ? 'bg-[var(--bg)] text-[var(--accent)]' : 'text-[var(--text)] hover:bg-[var(--bg)] hover:text-[var(--heading)]'}`}
                    >
                      <span class="font-medium">{order} | {chapter.title}</span>
                      <!-- 预留小字位置 -->
                      <div class="mt-0.5 h-4 text-xs text-[var(--text)] opacity-60"></div>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })}
    </nav>
  </div>
</aside>

<button
  id="sidebar-toggle"
  class="fixed left-4 top-4 z-50 rounded-md border border-[var(--border)] bg-[var(--surface)] p-2 text-[var(--text)] md:hidden"
  aria-label="打开导航"
>
  ☰
</button>

<script>
  (function () {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    if (!toggle || !sidebar) return;

    toggle.addEventListener('click', () => {
      sidebar.classList.toggle('-translate-x-full');
    });

    sidebar.addEventListener('click', (e) => {
      const link = e.target.closest('a');
      if (link) {
        sidebar.classList.add('-translate-x-full');
      }
    });

    // Accordion behavior
    const accordion = document.getElementById('topic-accordion');
    if (!accordion) return;

    accordion.addEventListener('click', (e) => {
      const header = e.target.closest('.topic-header');
      if (!header) return;

      const group = header.closest('.topic-group');
      if (!group) return;

      const chapters = group.querySelector('.topic-chapters');
      const chevron = header.querySelector('.topic-chevron');
      const isExpanded = header.getAttribute('aria-expanded') === 'true';

      if (chapters) {
        if (isExpanded) {
          chapters.classList.remove('max-h-[1000px]', 'opacity-100');
          chapters.classList.add('max-h-0', 'opacity-0');
        } else {
          chapters.classList.remove('max-h-0', 'opacity-0');
          chapters.classList.add('max-h-[1000px]', 'opacity-100');
        }
      }

      header.setAttribute('aria-expanded', String(!isExpanded));
      chevron?.classList.toggle('rotate-180');
    });
  })();
</script>
