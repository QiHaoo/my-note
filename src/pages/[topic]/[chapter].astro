---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ViewToggle from '../../components/ViewToggle.astro';
import MindmapViewer from '../../components/MindmapViewer.astro';
import { getTopics } from '../../lib/content';
import { renderMarkdown } from '../../lib/markdown';

export function getStaticPaths() {
  const topics = getTopics();
  const paths: any[] = [];
  for (const topic of topics) {
    for (const chapter of topic.chapters) {
      paths.push({
        params: { topic: topic.slug, chapter: chapter.slug },
        props: { topic, chapter },
      });
    }
  }
  return paths;
}

const { topic, chapter } = Astro.props;
const base = import.meta.env.BASE_URL || '';

const noteHref = `/${topic.slug}/${chapter.slug}/`;
const mindmapHref = `/${topic.slug}/${chapter.slug}/?view=mindmap`;

const subLinks = chapter.subChapters.map((sc) => ({
  title: sc.title,
  url: `${base}/${topic.slug}/${chapter.slug}/${sc.slug}/`,
}));
const noteHtml = chapter.note ? await renderMarkdown(chapter.note.rawContent, subLinks) : '';
const hasSubNotes = chapter.subChapters.length > 0;
---

<BaseLayout title={chapter.title}>
  <div class="mx-auto max-w-5xl">
    <div class="mb-6">
      <div class="text-sm text-[var(--text)]">
        {topic.meta.title} / {chapter.title}
      </div>
      <h1 class="mt-2 text-3xl font-bold text-[var(--heading)]">{chapter.title}</h1>
      {chapter.note?.frontmatter.tags && (
        <div class="mt-3 flex flex-wrap gap-2">
          {chapter.note.frontmatter.tags.map((tag) => (
            <span class="rounded-full border border-[var(--border)] px-2 py-0.5 text-xs text-[var(--text)]">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>

    {chapter.hasNote && chapter.hasMindmap && (
      <ViewToggle noteHref={noteHref} mindmapHref={mindmapHref} />
    )}

    {chapter.note && (
      <div id="note-panel" class="hidden">
        <article class="prose max-w-none" set:html={noteHtml} />

        {hasSubNotes && (
          <section class="subnotes-index mt-12 border-t border-[var(--border)] pt-8">
            <h2 class="mb-1 text-xl font-semibold text-[var(--heading)]">本章节分笔记</h2>
            <p class="mb-5 text-sm text-[var(--text)] opacity-80">深入阅读各专题细节</p>
            <div class="grid gap-3 sm:grid-cols-2">
              {chapter.subChapters.map((sc, idx) => {
                const num = String(idx + 1).padStart(2, '0');
                return (
                  <a
                    href={`${base}/${topic.slug}/${chapter.slug}/${sc.slug}/`}
                    class="group flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-4 transition-all hover:-translate-y-0.5 hover:border-[var(--accent)]"
                  >
                    <span class="font-mono text-xs text-[var(--text)] opacity-60">{num}</span>
                    <span class="font-medium text-[var(--heading)] group-hover:text-[var(--accent)]">{sc.title}</span>
                  </a>
                );
              })}
            </div>
          </section>
        )}
      </div>
    )}

    {chapter.mindmap && (
      <div id="mindmap-panel" class="hidden">
        <MindmapViewer data={chapter.mindmap} />
      </div>
    )}
  </div>

  <script is:inline>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const notePanel = document.getElementById('note-panel');
      const mindmapPanel = document.getElementById('mindmap-panel');
      const defaultView = notePanel ? 'note' : 'mindmap';
      const view = params.get('view') === 'mindmap' ? 'mindmap' : defaultView;

      if (view === 'note' && notePanel) {
        notePanel.classList.remove('hidden');
      }
      if (view === 'mindmap' && mindmapPanel) {
        mindmapPanel.classList.remove('hidden');
      }
    })();
  </script>
</BaseLayout>
